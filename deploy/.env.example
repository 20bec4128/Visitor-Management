# ── Per-tenant configuration ──────────────────────────────────────────────
# Copy this to tenants/<tenant>.env and fill in. Every customer gets their own
# copy with DIFFERENT values — especially DB_PASSWORD, AUTH_SECRET and the admin
# credentials. Never reuse AUTH_SECRET across tenants (it signs login tokens).

# A short, unique slug for this customer (letters, digits, hyphens).
TENANT_NAME=hospital-a

# Database (isolated per tenant).
DB_NAME=vms_hospital_a
DB_USER=vms
DB_PASSWORD=CHANGE-ME-strong-db-password

# Token signing secret — MUST be unique and random per tenant.
# Generate one: `openssl rand -base64 48`  (the script does this automatically).
AUTH_SECRET=CHANGE-ME-unique-random-secret

# The first admin login created on startup for this customer.
ADMIN_USERNAME=admin@hospital-a.com
ADMIN_PASSWORD=CHANGE-ME-admin-password

# Public URL this tenant is reached at (used for CORS / links in emails).
PUBLIC_URL=https://hospital-a.yourvms.com

# Host port the frontend is published on. Must be UNIQUE per tenant on the same
# server (e.g. 8080, 8081, 8082 …). Put a reverse proxy in front to map the
# subdomain → this port.
HTTP_PORT=8080
